{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ratedwatch",
  "main": "./src/worker/index.tsx",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],

  // workers_dev is DELIBERATELY left at its default (true). An
  // earlier attempt to flip it to false ([REVERTED commit in this
  // same PR branch]) took down every pr-<N>-ratedwatch.*.workers.dev
  // preview alias too — the flag is script-scoped, not
  // version-scoped, so disabling the default hostname also kills
  // the --preview-alias hostnames that CI relies on for E2E tests.
  //
  // Canonical URL is still rated.watch (via cloudflare_workers_
  // custom_domain.apex + workers_route.wildcard_subdomain in
  // infra/terraform/). Treat ratedwatch.nmoura.workers.dev as a
  // fallback / admin-only hostname. If noindex matters later, add
  // an X-Robots-Tag: noindex header on non-rated.watch hosts.

  // Workers Assets serves the Vite build output.
  //
  //  - The Worker owns `/` (SSR landing page), `/leaderboard` (SSR public
  //    leaderboard, slice #13), `/m/*` (SSR per-movement pages, slice
  //    #14), and `/api/*` via run_worker_first. Future public HTML
  //    routes (/u/:name, /w/:id) will be added here as they land.
  //  - Everything else falls through to assets. not_found_handling =
  //    single-page-application rewrites unknown paths to /index.html so
  //    the SPA's client-side router (react-router) can take over.
  //  - ASSETS binding lets the Worker programmatically fetch assets if it
  //    ever needs to compose them (e.g. injecting SPA bootstrap data).
  "assets": {
    "directory": "./dist/",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/leaderboard",
      "/m/*",
      "/u/*",
      "/w/*",
      "/out/*",
      "/api/*",
      "/images/*",
      "/robots.txt",
      "/sitemap.xml"
    ]
  },

  // Data layer bindings. IDs come from `terraform output` in
  // infra/terraform/. Keep in sync; `npm run types:gen` regenerates
  // worker-configuration.d.ts whenever this file changes.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "rated-watch-db",
      "database_id": "476d116f-b684-4f23-bdfb-119ad08f1e55",
      // Schema lives in ./migrations. `wrangler d1 migrations apply` and
      // vitest-pool-workers' readD1Migrations() both read from this
      // directory. Files are numbered (0001_…, 0002_…, …) and applied
      // in lexical order.
      "migrations_dir": "./migrations"
    }
  ],
  "r2_buckets": [
    // User-uploaded watch profile photos. Renamed from `IMAGES` to
    // `WATCH_IMAGES` in slice #2 of PRD #99 (this PR) so the
    // `IMAGES` name could be re-used for the new Cloudflare Images
    // binding (`env.IMAGES.input(...).transform(...)`). The bucket
    // itself (`rated-watch-images`) is unchanged — only the Worker-
    // side binding name moved.
    {
      "binding": "WATCH_IMAGES",
      "bucket_name": "rated-watch-images"
    },
    {
      "binding": "LOGS",
      "bucket_name": "rated-watch-logs"
    },
    // Training corpus — slice #81 of PRD #73. Receives photo +
    // anonymized JSON sidecar pairs when a verified-reading
    // attempt rejects or succeeds with low-margin confidence,
    // conditional on the user's `consent_corpus` toggle. The
    // bucket is operator-private; no Worker route serves bytes
    // back. The TF resource lives in infra/terraform/r2.tf.
    {
      "binding": "R2_CORPUS",
      "bucket_name": "rated-watch-corpus"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "FLAGS",
      "id": "b4298bd1887d4dae8d1c113ec99cea56"
    }
  ],

  // Workers AI binding — re-introduced in slice #3 of PRD #99
  // (issue #102) to drive the new Worker-side VLM dial reader.
  // The dial-reader-vlm module (src/domain/dial-reader-vlm/) calls
  // `env.AI.run("openai/gpt-5.2", body, { gateway: { id: env.AI_GATEWAY_ID } })`
  // and routes the request through Cloudflare AI Gateway for
  // unified-billing accounting and gateway-side caching/logs.
  //
  // Production gateway slug `ratedwatch-vlm` is provisioned by
  // slice #9; until then we default to the bake-off gateway
  // (`dial-reader-bakeoff`) which already exists in the account.
  "ai": {
    "binding": "AI",
    // AI bindings always access remote resources (there is no local
    // emulator). Mark `remote: true` to silence the wrangler warning
    // about possible local-dev usage charges. In tests we still
    // never reach this code path because the reader uses an
    // injected mock `AiClient`; vitest-pool-workers' `remoteBindings:
    // false` (vitest.config.ts) keeps the binding from contacting
    // the gateway during integration tests.
    "remote": true
  },

  // Cloudflare Images binding — the dial-cropper module
  // (src/domain/dial-cropper/) uses `env.IMAGES.input(bytes)
  // .transform(...).output(...)` for HEIC decode, EXIF auto-rotation,
  // 1024-px-long-edge downsampling, and the final 768×768 crop. Sharp
  // runs at the edge in C++; the JS HoughCircles + jpeg-js decode
  // step inside dial-cropper handles the actual circle detection.
  // Slice #2 of PRD #99 introduces this binding; slice #4 wires the
  // verified-reading endpoint through it. Per Cloudflare docs every
  // call to env.IMAGES counts as a billable transformation.
  "images": {
    "binding": "IMAGES"
  },

  // AI Gateway slug to route VLM calls through. Per-environment
  // override is supported via wrangler `[env.<name>] vars`. The
  // default value here is the bake-off gateway, which is what
  // dev / test / preview deploys want until slice #9 creates the
  // production gateway.
  "vars": {
    "AI_GATEWAY_ID": "dial-reader-bakeoff"
  },

  // The verified-reading dial reader (Python container + Durable
  // Object plus its `DIAL_READER` binding) was decommissioned in
  // slice #1 of PRD #99 (issue #100). The replacement Worker-side
  // VLM pipeline lands in slice #4 (issue #103). Until then
  // `/readings/verified` and `/readings/manual_with_photo` return
  // 503.
  //
  // Migrations: the `v1` migration that introduced
  // `DialReaderContainer` as a SQLite-backed DO class is kept here
  // so wrangler does not try to re-apply it (migrations are
  // identified by tag and are append-only). The new `v2` migration
  // tells the runtime to drop the class entirely — required
  // because the script no longer exports `DialReaderContainer`.
  // Without this, wrangler refuses to deploy with `code: 10064`
  // ("New version of script does not export class
  // 'DialReaderContainer' which is depended on by existing Durable
  // Objects").
  //
  // Operator follow-up post-merge:
  //   - Delete `ratedwatch-dialreadercontainer:*` images from
  //     Cloudflare Container Registry.
  //   - The DialReaderContainer DO class will be removed by the
  //     v2 migration on the next prod deploy.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DialReaderContainer"]
    },
    {
      "tag": "v2",
      "deleted_classes": ["DialReaderContainer"]
    }
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // Analytics Engine — product-event firehose (slice #19). All domain
  // events (user_registered, watch_added, reading_submitted,
  // chrono24_click, page_view_*, …) flow through
  // src/observability/events.ts → env.ANALYTICS.writeDataPoint. The
  // `rw_events` dataset is queryable via the Analytics Engine SQL API.
  // See https://developers.cloudflare.com/analytics/analytics-engine/.
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "rw_events"
    }
  ],

  // The verified-reading rate-limit binding
  // (`VERIFIED_READING_LIMITER`) was removed in slice #1 of PRD #99
  // (issue #100) alongside the rest of the dial-reader plumbing.
  // The replacement VLM pipeline (slice #4 — issue #103) will
  // re-introduce a rate-limit binding when the verified-reading
  // surface comes back online.

  // ---------------------------------------------------------------
  // Runtime secrets (NOT stored here — set via `wrangler secret put`)
  // ---------------------------------------------------------------
  //
  //   BETTER_AUTH_SECRET    — cookie signing key. 32+ chars of entropy
  //                            (openssl rand -base64 32).
  //   GOOGLE_CLIENT_ID      — Google OAuth 2.0 client ID from the
  //                            Google Cloud Console.
  //   GOOGLE_CLIENT_SECRET  — matching OAuth client secret.
  //   SENTRY_DSN            — Sentry DSN for the Worker
  //                            (`withSentry` in
  //                            src/observability/sentry.ts). Missing
  //                            DSN is a no-op — the wrapper degrades
  //                            to a passthrough so local dev and
  //                            freshly-provisioned previews boot
  //                            cleanly without the secret.
  //
  // When the Google pair is unset the Worker still boots and
  // email+password flows work; only the Google social provider is
  // skipped. See AGENTS.md ("Secrets") for the full operator handoff
  // including required Authorized Redirect URIs.
}
