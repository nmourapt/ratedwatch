# Local development environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Runtime secrets for the Worker itself (JWT-like things, Google OAuth client secret, Sentry DSN, etc.)
# are NOT kept here — they live in `wrangler secret put <KEY>` and `.dev.vars` (for local dev).
# This `.env` is only for local tooling (Terraform, scripts, CI bootstrap) that runs OUTSIDE the Worker.

# --- Cloudflare ---

# Bootstrap token — has "Account API Tokens Write" permission.
# Used by infra/terraform/ (slice #3) to mint narrowly-scoped tokens for TF, Wrangler, CI.
# Once scoped tokens are in place, this bootstrap token can (and should) be rotated/revoked.
CLOUDFLARE_BOOTSTRAP_TOKEN=

# Cloudflare account ID owning the rated.watch zone.
# For this project: Babybites account, d94d0ebef658cbd92166d633c8f065c9
CLOUDFLARE_ACCOUNT_ID=

# rated.watch zone ID on the Babybites account.
# 41a9c69cf1fb3589b93ed1c989881e7a
CLOUDFLARE_ZONE_ID_RATED_WATCH=

# --- Terraform S3 backend (R2-backed) ---
# Pattern borrowed from ~/nmoura-cf/. Use the R2 S3 credentials of the state-holding account.

TF_S3_ACCESS_KEY_ID=
TF_S3_SECRET_ACCESS_KEY=
TF_S3_ENDPOINT=
