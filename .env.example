# Local-tooling environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# These variables are for tooling that runs OUTSIDE the Worker (Terraform,
# bootstrap scripts, CI). Runtime Worker secrets go via `wrangler secret put`
# or `.dev.vars` (see AGENTS.md). Wrangler is explicitly configured to skip
# `.env` via CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false in every npm script.

# --- Cloudflare account + zone ---

# Account that owns the rated.watch zone.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCOUNT_NAME=

# rated.watch zone ID.
CLOUDFLARE_ZONE_ID_RATED_WATCH=

# --- Bootstrap token (one-time) ---

# Has only the "Account API Tokens Write" permission.
# Used exactly once, by infra/terraform/scripts/bootstrap.sh, to mint the
# scoped CLOUDFLARE_API_TOKEN below and the R2 state bucket + S3 creds.
# Rotate/revoke this token once the scoped token is in place.
CLOUDFLARE_BOOTSTRAP_TOKEN=

# --- Terraform-scoped API token (minted by bootstrap) ---

# Scope: D1/R2/KV/Workers Scripts/Workers Tail on the account;
# DNS/Zone Read/Workers Routes on the rated.watch zone.
# The Cloudflare Terraform provider reads this automatically.
# Does NOT have API Tokens Write — rotation requires the bootstrap token.
CLOUDFLARE_API_TOKEN=

# --- Terraform state backend (R2, via S3-compatible API) ---

# The R2 state bucket `ratedwatch-tfstate` lives in the same Cloudflare
# account as the resources it manages.
#
# Per https://developers.cloudflare.com/r2/api/tokens/, CF API tokens work
# as S3 credentials:
#   Access Key ID     = CF API token id
#   Secret Access Key = sha256 of the CF API token value
# The bootstrap script computes these from CLOUDFLARE_API_TOKEN.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_REGION=auto
